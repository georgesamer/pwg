<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console appender with a clear pattern -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- DEBUG for our application package to see step-by-step details -->
    <logger name="com.church.festival" level="DEBUG" />

    <!-- Default root logger -->
    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
